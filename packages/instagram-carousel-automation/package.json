{
  "name": "@geetbih/instagram-automation",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./src/pipeline.ts",
  "exports": {
    ".": "./src/pipeline.ts",
    "./config": "./src/config.ts",
    "./domain": "./src/domain/types.ts"
  },
  "engines": {
    "node": ">=22.12 <23 || >=24"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "pipeline": "tsx src/cli.ts",
    "pipeline:dry": "tsx src/cli.ts --dry-run",
    "preflight": "tsx scripts/preflight.ts",
    "auth": "tsx scripts/auth.ts",
    "render:dry": "npm run pipeline:dry"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cloudinary": "^2.7.0",
    "dotenv": "^16.6.0",
    "express": "^5.2.1",
    "node-fetch": "^3.3.2",
    "openai": "^6.42.0",
    "playwright": "^1.52.0",
    "rss-parser": "^3.13.0",
    "sharp": "^0.34.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/server-memory": "^2026.1.26",
    "@types/express": "^5.0.6",
    "@types/node": "^22.15.0",
    "@types/node-fetch": "^2.6.13",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
