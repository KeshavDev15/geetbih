generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLead {
  id        String   @id @default(cuid())
  email     String?  // Optional initially, might collect at the end
  bottleneck String
  scale     String
  status    String   @default("NEW") // NEW, CONTACTED, ARCHIVED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
